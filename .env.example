# Copy to .env and fill in. .env is gitignored and is injected at runtime
# (docker compose env_file) — NEVER bake these into image layers, settings.json,
# the DB, or client code.

# ---- App / runtime config (replaces settings.json in the container) ----
NODE_ENV=production
PORT=3060
# Public base URL (used for magic-link + Stripe redirect URLs).
BASE_URL=https://enkeletikett.se
APP_NAME=bakery-labels
SESSION_DAYS=30
MAGIC_LINK_MINUTES=15
# First user with this email is promoted to admin on creation.
FIRST_ADMIN_EMAIL=fredrik@lundstream.net
# SQLite database file (mount a volume at this directory).
DB_PATH=/app/data/app.db

# Express trust-proxy for the Cloudflare -> your proxy -> app chain so req.ip,
# secure-cookie detection and any rate limiting see the real client IP.
# Accepts a hop COUNT (e.g. 2) or a trusted subnet/CIDR. Do NOT use "true"
# (that trusts arbitrary X-Forwarded-For and lets clients spoof their IP).
# See README — pick the value that matches your proxy chain.
TRUST_PROXY=2

# ---- Email (Resend) ----
# Secret — env only.
RESEND_API_KEY=
EMAIL_FROM=Enkel Etikett <noreply@enkeletikett.se>

# ---- Stripe billing — Phase 1 ----
# SERVER-SIDE ONLY. Never commit real values, never put these in settings.json or
# the DB, never ship them to the client.

# Secret API key (Dashboard → Developers → API keys). Use a test key in dev.
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret for the /api/billing/webhook endpoint
# (Dashboard → Developers → Webhooks → your endpoint → Signing secret),
# or the `whsec_...` printed by `stripe listen` during local development.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price id of the subscription the Checkout Session sells
# (Dashboard → Product catalog → your price → price id).
STRIPE_PRICE_ID=price_xxx

# --- Server-side export (Phase 2) ---
# PDF/PNG are rendered in headless Chromium (puppeteer) by loading the SPA's
# /__export route. By default the API loads it from its own origin, which serves
# the built dist in production. In dev the API doesn't serve the SPA, so point
# this at a running build (Vite preview / dev server), e.g. http://localhost:3050.
# EXPORT_BASE_URL=http://localhost:3050
