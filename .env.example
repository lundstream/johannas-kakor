# Stripe billing — Phase 1
# SERVER-SIDE ONLY. Never commit real values, never put these in settings.json or
# the DB, never ship them to the client. Copy this file to .env and fill it in.
#
# .env is gitignored. In production, set these as real environment variables.

# Secret API key (Dashboard → Developers → API keys). Use a test key in dev.
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret for the /api/billing/webhook endpoint
# (Dashboard → Developers → Webhooks → your endpoint → Signing secret),
# or the `whsec_...` printed by `stripe listen` during local development.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Price id of the subscription the Checkout Session sells
# (Dashboard → Product catalog → your price → price id).
STRIPE_PRICE_ID=price_xxx
